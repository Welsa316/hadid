# Base URL of the Hadid sync backend (the server/ service).
# Leave unset to build an offline-only app with no sync.
#
# Local development (server/ running via `npm run dev`):
#   VITE_SYNC_URL=http://localhost:8787
# Production, after deploying server/ to Railway:
#   VITE_SYNC_URL=https://your-sync-service.up.railway.app
VITE_SYNC_URL=
